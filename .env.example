# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# Set to true when running behind HTTPS (reverse proxy). Leave false for local dev.
COOKIE_SECURE=false

# The public URL of this app (used to build the Plex OAuth callback URL)
# For local dev: http://localhost:3000
# For production: https://your-domain.com
APP_URL=https://your-domain.com

# ── Plex ──────────────────────────────────────────────────
# Your Plex server URL as seen FROM the Docker container.
# Use the local/LAN address — not your external domain — so transcoding
# requests stay on your LAN and don't round-trip through your reverse proxy.
# Examples:
#   http://host.docker.internal:32400   (Docker on Windows/Mac)
#   http://192.168.1.100:32400          (LAN IP if host.docker.internal doesn't work)
PLEX_URL=http://host.docker.internal:32400

# Your Plex server token (Settings → Troubleshooting → "Your Plex Token" link)
PLEX_TOKEN=your-plex-token-here

# Unique identifier for this app (any stable string is fine)
# Required: unique identifier for this app in Plex OAuth flows (e.g. your-app-name-prod)
PLEX_CLIENT_ID=your-unique-app-id

# Default timezone for scheduled rooms (IANA timezone string, e.g. America/New_York).
# Used when the client doesn't send a valid timezone.
DEFAULT_TIMEZONE=America/New_York

# ── Room Types ─────────────────────────────────────────────
# Set to false to hide a room type from the lobby.
ROOM_TYPE_MOVIE=true
ROOM_TYPE_TV=true
ROOM_TYPE_YOUTUBE=true
ROOM_TYPE_LIVETV=false

# ── Live TV (requires ROOM_TYPE_LIVETV=true) ───────────────
# HDHomeRun device on your LAN
HDHR_IP=172.21.1.115
HDHR_PORT=5004
LIVETV_DEFAULT_CHANNEL=7.1
# Plex server used for EPG guide data (can differ from PLEX_URL)
LIVETV_PLEX_HOST=http://192.168.1.225:32400
# Token for the Live TV Plex server. If unset, falls back to PLEX_TOKEN.
# LIVETV_PLEX_TOKEN=
# Public IP advertised in WebRTC ICE candidates. Must be an IP address, not a hostname.
# Required for viewers outside the LAN. Falls back to the hostname in APP_URL (unreliable).
# WEBRTC_ANNOUNCED_IP=203.0.113.10
#
# UDP port range for WebRTC media. Open this range on your firewall/router.
# Default: 40000-40100
# WEBRTC_PORT_MIN=40000
# WEBRTC_PORT_MAX=40100

